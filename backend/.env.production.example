ENV=production

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority&appName=peekori
MONGO_DB_NAME=candyman

# Optional extra databases currently used by admin flows
MONGO_URI_df=
MONGO_URI_YIPPEE=

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_EMAIL=admin@peekori.com
JWT_SECRET=replace-with-strong-random-secret
ADMIN_JWT_SECRET=replace-with-strong-random-secret
ADMIN_JWT_TTL_HOURS=24
CREATOR_JWT_SECRET=replace-with-creator-secret
CREATOR_JWT_TTL_HOURS=720

# Repo / storefront links
CUTETALES_FRONTEND_BASE_URL=https://peekori.com
CUTETALES_REPO_PATH=/srv/peekori/cutetales-storybook
NEXT_PUBLIC_API_BASE_URL=https://admin-api.peekori.com

# Email
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=

# Google Sheets / service accounts
GOOGLE_SHEET_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=Order Placement
GOOGLE_VALUE_INPUT_OPTION=USER_ENTERED
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID_YARA=
GOOGLE_SHEET_WORKSHEET_YARA=Sheet1
GOOGLE_VALUE_INPUT_OPTION_YARA=USER_ENTERED
GOOGLE_SERVICE_ACCOUNT_FILE_YARA=

# Shipping / printer / webhooks
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE=https://apiv2.shiprocket.in/v1/external
CLOUDPRINTER_API_KEY=

# AWS / storage
AWS_REGION=ap-south-1
REPLICACOMFY_BUCKET=
DIFFRUN_GENERATIONS_BUCKET=
